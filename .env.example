HF_TOKEN=your_huggingface_token_here
MODEL_VERSION=v1.0.0
PORT=8000
API_KEY=replace_with_min_32_char_secret
EMBEDDING_MODEL=intfloat/multilingual-e5-base
DEVICE=cpu
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=iw-ml-service
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_S=60
ML_SERVICE_URL=http://localhost:8001

# Platform connectors
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
YOUTUBE_POLL_INTERVAL=300
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password
SOCIAVAULT_API_KEY=your_sociavault_key
SOCIAVAULT_POLL_INTERVAL=3600

# Counter-response generation — Section 6.5
COUNTER_RESPONSE_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile